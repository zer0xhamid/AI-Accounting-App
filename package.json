{
  "name": "ai-accounting-app",
  "version": "1.2.0",
  "description": "برنامج محاسبي ذكي يعتمد على الذكاء الاصطناعي",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --win"
  },
  "author": "",
  "license": "UNLICENSED",
  "build": {
    "appId": "com.smart-accountant.app",
    "productName": "المحاسب الذكي",
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      "resources/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "zer0xhamid",
        "repo": "AI-Accounting-App"
      }
    ],
    "artifactName": "${name}-setup-${version}.${ext}",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "unicode": true
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.500.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  }
}
